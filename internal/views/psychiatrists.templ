package views

import (
    "fmt"
    "github.com/gattini0928/Equilibrium/internal/models"
)

templ PsychiatristsPage(psychiatrists []models.DoctorWithUser, isAuth bool) {
    @Layout("Psiquiatras", isAuth) {
     <main class="doctors-page">
        <h2>Nossos Psiquiatras</h2> 
        if len(psychiatrists) == 0 {
            <span class="msg">Por enquanto não possuímos nenhum psiquiatra</span>
        }
        <div class="cards">       
            for _, psychiatrist := range psychiatrists {
                <div class="card">
                    <div class="img-wrapper-doctor">
                        <img src={psychiatrist.Image} alt="Foto de Perfil do Psiquiatra">                  
                    </div>
                    <div class="infos">
                        <span class="name">{psychiatrist.Name}</span>
                        <span class="email">{psychiatrist.Email}</span>
                        <span class="email">Idade: {psychiatrist.Age} anos</span>
                        <span class="crm">CRM: {psychiatrist.CRM}</span>
                    </div>
                    <div class="description">
                        <h3>Um pouco sobre mim</h3>
                        <p>{psychiatrist.Description}</p>
                    </div>
                    <a href={ templ.URL(fmt.Sprintf("/psychiatrists/id/%d", psychiatrist.ID)) } class="psychiatrist-link">Ver Agenda</a>
                </div>              
            }
        </div>
    </main>
    }
}